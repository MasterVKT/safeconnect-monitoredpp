<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Monitored App</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>monitored_app</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	
	<!-- Background Modes -->
	<key>UIBackgroundModes</key>
	<array>
		<string>background-app-refresh</string>
		<string>background-processing</string>
		<string>location</string>
		<string>remote-notification</string>
		<string>background-fetch</string>
	</array>
	
	<!-- Background Task Identifiers -->
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.xpsafeconnect.monitored-app.refresh</string>
		<string>com.xpsafeconnect.monitored-app.processing</string>
	</array>
	
	<!-- Location Permissions -->
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>This app needs location access for safety monitoring and emergency response.</string>
	<key>NSLocationAlwaysUsageDescription</key>
	<string>This app needs background location access for continuous safety monitoring.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>This app needs location access for safety monitoring and emergency response.</string>
	
	<!-- Face ID Permission -->
	<key>NSFaceIDUsageDescription</key>
	<string>This app uses Face ID for secure authentication to access monitoring controls.</string>
	
	<!-- Camera Permission -->
	<key>NSCameraUsageDescription</key>
	<string>This app needs camera access for emergency photo capture and safety monitoring.</string>
	
	<!-- Microphone Permission -->
	<key>NSMicrophoneUsageDescription</key>
	<string>This app needs microphone access for emergency audio recording and safety monitoring.</string>
	
	<!-- Photo Library Permission -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>This app needs photo library access for safety monitoring and emergency response.</string>
	
	<!-- Local Network Permission -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>This app needs local network access for secure communication with monitoring systems.</string>
	
	<!-- Prevent app from appearing in usage statistics -->
	<key>SBAppUsageReportingEnabled</key>
	<false/>
	
	<!-- Allow app to run in background -->
	<key>UIBackgroundRefreshEnable</key>
	<true/>
	
	<!-- Required device capabilities -->
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>location-services</string>
	</array>
</dict>
</plist>
