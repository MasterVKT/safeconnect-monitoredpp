{
  "model":"opusplan",
  "env": {
    "ENABLE_TOOL_SEARCH": "true",
    "DISABLE_AUTOUPDATER": "1",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "ENABLE_PROMPT_CACHING_1H": "1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|write_file|MultiEdit|str_replace_based_edit_tool",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/lsp_diagnostics.sh",
            "shell": "bash"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/prettier_format.sh",
            "shell": "bash"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/activate_venv_bash.sh",
            "shell": "bash"
          }
        ]
      },
      {
        "matcher": "PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "& '.claude\\hooks\\activate_venv_ps1.ps1'",
            "shell": "powershell"
          }
        ]
      },
      {
        "matcher": "Read|View|read_file",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/ast_elision.py",
            "shell": "bash"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/log_filter.sh",
            "shell": "bash"
          }
        ]
      },
      {
        "matcher": "Task|TodoWrite|attempt_completion",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/repomap_startup.sh",
            "shell": "bash"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[ORCHESTRATEUR] PRE-CONDITION OBLIGATOIRE: Avant de traiter cette requete - 1 - Selectionner la skill optimale via skills/task-orchestrator/SKILL.md - 3- Executer le workflow complet. Aucune implementation ne peut preceder ce routage.\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[DOUBLE CHECK GATE] OBLIGATOIRE avant envoi : 1- Relire la requete originale mot pour mot. 2- Verifier chaque exigence contre ce qui a ete fait. 3- Corriger tout ecart silencieusement. 4- Envoyer seulement apres verification complete.\""
          }
        ]
      }
    ]
  }
}
